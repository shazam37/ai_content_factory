# Database
POSTGRES_USER=content_factory
POSTGRES_PASSWORD=content_factory
POSTGRES_DB=content_factory
DATABASE_URL=postgresql+asyncpg://content_factory:content_factory@db:5432/content_factory

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to: groq | openai | anthropic | gemini | ollama | auto
# "auto" infers the provider from the model name (recommended).
LLM_PROVIDER=auto

# The model name for script generation.
# Groq examples  : llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
# OpenAI examples: gpt-4o, gpt-4o-mini
# Anthropic      : claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5
# Gemini         : gemini-1.5-pro, gemini-1.5-flash
# Ollama (local) : qwen2.5:7b, llama3.2:3b
LLM_MODEL=openai/gpt-oss-120b

# Optional: a lighter/cheaper model just for quality scoring.
# Leave empty to reuse LLM_MODEL.
LLM_QUALITY_MODEL=llama-3.3-70b-versatile

# API keys — only fill in the key for the provider you are using.
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Ollama (local inference fallback) ────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_QUALITY_MODEL=qwen2.5:7b

# Storage
STORAGE_BASE_PATH=./storage

# Content Settings
DEFAULT_VIDEO_WIDTH=1080
DEFAULT_VIDEO_HEIGHT=1920
DEFAULT_VIDEO_FPS=30
DEFAULT_NICHE=science

# Voice Generation (edge-tts)
# Available voices: en-US-GuyNeural, en-US-JennyNeural, en-GB-RyanNeural, en-AU-WilliamNeural
VOICE_DEFAULT=en-US-GuyNeural
VOICE_FEMALE=en-US-JennyNeural

# Image Generation
# Options: ffmpeg_slides, pexels
IMAGE_PROVIDER=ffmpeg_slides

# Pexels API (optional - get free key at pexels.com/api)
PEXELS_API_KEY=

# Trend Discovery
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ContentFactory/1.0

# API Settings
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

VOICE_PROVIDER=edge_tts